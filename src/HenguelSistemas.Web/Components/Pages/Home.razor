            }

        .pricing-currency { font-family: var(--font-head); font-weight: 700; font-size: 1.1rem; color: var(--blue-900); padding-bottom: 8px; }
        .pricing-value { font-family: var(--font-head); font-weight: 800; font-size: 3rem; color: var(--blue-900); line-height: 1; }
        .pricing-period { font-size: .9rem; color: var(--gray-500); padding-bottom: 8px; }

        .pricing-desc { font-size: .9rem; color: var(--gray-500); margin-bottom: 28px; line-height: 1.5; }

        .pricing-divider { border: none; border-top: 1px solid var(--gray-200); margin-bottom: 24px; }

        .pricing-features { list-style: none; display: flex; flex-direction: column; gap: 12px; margin-bottom: 32px; }

        .pricing-features li {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            font-size: .9rem;
            color: var(--gray-700);
            line-height: 1.4;
        }

        .pricing-features li .check { color: var(--green); font-size: 1rem; margin-top: 1px; flex-shrink: 0; }

        .pricing-cta { width: 100%; padding: 15px; font-size: .95rem; border-radius: var(--radius-md); justify-content: center; }

        .pricing-note {
            text-align: center;
            margin-top: 40px;
            padding: 20px 28px;
            background: linear-gradient(135deg, #e8f5e9, #f0fff4);
            border: 1px solid #a5d6a7;
            border-radius: var(--radius-md);
            font-size: .95rem;
            color: #2e7d32;
            font-weight: 500;
        }

        .pricing-note strong { font-family: var(--font-head); }

        /* ─── WAITLIST ─── */
        #lista-espera {
            padding: 100px 0;
            background: var(--blue-50);
            position: relative;
            overflow: hidden;
        }

        #lista-espera::before {
            content: '';
            position: absolute;
            top: -80px; right: -100px;
            width: 500px; height: 500px;
            background: radial-gradient(circle, rgba(0,180,216,.12) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .waitlist-box {
            position: relative;
            z-index: 1;
            max-width: 560px;
            margin: 0 auto;
        }

        .waitlist-box h3 {
            font-family: var(--font-head);
            font-size: clamp(1.6rem, 3vw, 2.2rem);
            font-weight: 800;
            color: var(--blue-900);
            letter-spacing: -.8px;
            margin-bottom: 12px;
        }

        .waitlist-box > p { color: var(--gray-500); font-size: 1rem; line-height: 1.6; margin-bottom: 24px; }

        .waitlist-perks {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-bottom: 32px;
            padding: 20px 24px;
            background: var(--white);
            border: 1px solid var(--gray-200);
            border-radius: var(--radius-md);
            box-shadow: var(--shadow-sm);
        }

        .waitlist-perk {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: .9rem;
            color: var(--gray-700);
        }

        .waitlist-perk .perk-icon { font-size: 1rem; }

        .waitlist-perk s { color: var(--gray-500); text-decoration: line-through; }
        .waitlist-perk strong { color: var(--green); font-weight: 700; }

        .form-group { display: flex; flex-direction: column; gap: 14px; margin-bottom: 14px; }

        .form-group input[type="text"],
        .form-group input[type="email"] {
            width: 100%;
            padding: 15px 20px;
            border: 1.5px solid var(--gray-200);
            border-radius: var(--radius-md);
            font-family: var(--font-body);
            font-size: .95rem;
            color: var(--text);
            background: var(--white);
            outline: none;
            transition: border-color .2s, box-shadow .2s;
            box-shadow: var(--shadow-sm);
        }

        .form-group input:focus { border-color: var(--blue-400); box-shadow: 0 0 0 4px rgba(21,101,192,.1); }

        .consent {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            font-size: .875rem;
            color: var(--gray-500);
            cursor: pointer;
            margin-bottom: 20px;
        }

        .consent input[type="checkbox"] { width: 18px; height: 18px; margin-top: 1px; accent-color: var(--blue-600); flex-shrink: 0; cursor: pointer; }

        .waitlist-btn { width: 100%; padding: 17px; font-size: 1rem; border-radius: var(--radius-md); justify-content: center; }

        .waitlist-count { margin-top: 24px; font-size: .9rem; color: var(--gray-500); }
        .waitlist-count strong { color: var(--blue-600); font-family: var(--font-head); font-weight: 700; }

        .form-msg { padding: 14px 18px; border-radius: var(--radius-sm); font-size: .9rem; font-weight: 500; margin-bottom: 20px; }
        .form-msg.success { background: #e8f5e9; color: #2e7d32; border: 1px solid #a5d6a7; }
        .form-msg.error   { background: #fce4ec; color: #c62828; border: 1px solid #ef9a9a; }

        /* ─── FAQ ─── */
        #faq { padding: 80px 0; background: var(--white); }

        .faq-list { max-width: 720px; display: flex; flex-direction: column; gap: 16px; }

        .faq-item {
            border: 1px solid var(--gray-200);
            border-radius: var(--radius-md);
            overflow: hidden;
            background: var(--white);
            box-shadow: var(--shadow-sm);
        }

        .faq-question {
            width: 100%;
            background: none;
            border: none;
            padding: 20px 24px;
            text-align: left;
            font-family: var(--font-head);
            font-weight: 700;
            font-size: .95rem;
            color: var(--blue-900);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            transition: background .2s;
        }

        .faq-question:hover { background: var(--gray-100); }
        .faq-question .faq-arrow { font-size: .7rem; color: var(--blue-500); flex-shrink: 0; }

        .faq-answer {
            padding: 0 24px 20px;
            font-size: .92rem;
            color: var(--gray-500);
            line-height: 1.7;
            display: none;
        }

        .faq-answer.open { display: block; }

        /* ─── FOOTER ─── */
        footer { background: var(--blue-900); color: rgba(255,255,255,.5); padding: 40px 0; text-align: center; font-size: .85rem; }
        footer a { color: rgba(255,255,255,.7); text-decoration: none; transition: color .2s; }
        footer a:hover { color: var(--white); }

        /* ─── ANIMATIONS ─── */
        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(24px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        @@keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }

        /* ─── RESPONSIVE ─── */
        @@media (max-width: 860px) {
            .hw-wrap { padding: 0 16px; }
            #inicio .hw-wrap { grid-template-columns: 1fr; gap: 40px; padding-top: 60px; }
            .hero-visual-badge, .hero-visual-badge2 { display: none; }
            .pricing-grid { grid-template-columns: 1fr; max-width: 420px; }
            .nav-toggle { display: inline-flex; align-items: center; }
            .nav-links {
                display: none;
                position: absolute;
                top: 64px;
                left: 0;
                right: 0;
                background: rgba(255,255,255,.98);
                backdrop-filter: blur(20px);
                -webkit-backdrop-filter: blur(20px);
                border-bottom: 1px solid var(--gray-200);
                padding: 12px 20px 16px;
                flex-direction: column;
                gap: 8px;
            }
            #navbar.open .nav-links { display: flex; }
        }

        @@media (max-width: 600px) {
            .hero-actions { flex-direction: column; }
            .btn-primary, .btn-ghost { justify-content: center; text-align: center; }
            .proof-strip { gap: 32px; }
            .whatsapp-float { width: 50px; height: 50px; font-size: 24px; }
            .whatsapp-float img { width: 24px; height: 24px; }
        }

        .pricing-showcase {
            display: grid;
            grid-template-columns: minmax(0, 1fr) 1fr;
            gap: 48px;
            align-items: center;
            max-width: 1100px;
            margin: 0 auto;
        }

        .pricing-image img {
            width: 100%;
            height: auto;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--gray-200);
        }

        @@media (max-width: 900px) {
            .pricing-showcase {
                grid-template-columns: 1fr;
            }

            .pricing-image {
                order: -1;
            }
        }

        /* ─── RESPONSIVIDADE (smartphones) ─── */
        #responsividade {
            padding: 100px 0;
            background: var(--white);
            overflow: hidden;
        }

            #responsividade .hw-wrap {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 60px;
                align-items: center;
            }

        .resp-text {
        }

        .resp-phones {
            position: relative;
            width: 300px;
            height: 620px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .resp-phone {
            position: absolute;
            width: 300px;
            border-radius: 32px;
            /* REMOVA: box-shadow: var(--shadow-lg); */
            filter: drop-shadow(0 24px 40px rgba(21,101,192,.22));
            transition: transform 0.1s ease-out;
            will-change: transform;
        }

        .resp-phone-light {
            left: 50%;
            transform: translateX(-58%) rotate(-6deg);
            z-index: 1;
        }

        .resp-phone-dark {
            left: 50%;
            transform: translateX(-38%) rotate(4deg);
            z-index: 2;
        }

        @@media (max-width: 860px) {
            #responsividade .hw-wrap

        {
            grid-template-columns: 1fr;
            gap: 40px;
        }

        .resp-phones {
            height: 480px;
        }

        .resp-phone {
            width: 220px;
        }

        }</style>
</HeadContent>

