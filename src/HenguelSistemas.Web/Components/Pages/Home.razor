                    </label>

                    <button class="btn-primary waitlist-btn"
                            disabled="@_loading"
                            @onclick="SubmitWaitlistAsync">
                        @(_loading ? "Enviando..." : "🚀 Quero meu acesso gratuito →")
                    </button>
                }

                <p class="waitlist-count">
                    🔥 <strong>@(12 + _waitlistCount)</strong> empresas já garantiram acesso antecipado

