                @if (!string.IsNullOrEmpty(_formMessage))
                {
                    <div class="form-msg @_formMsgClass" role="status" aria-live="polite">@_formMessage</div>
                }

                @if (!_submitted)
                {
                    <div class="form-group">
                        <label class="sr-only" for="waitlist-name">Nome completo</label>
                        <input id="waitlist-name"
                               name="name"
                               type="text"
                               autocomplete="name"
                               placeholder="Seu nome completo"
                               @bind="_name" />

                        <label class="sr-only" for="waitlist-email">E-mail</label>
                        <input id="waitlist-email"
                               name="email"
                               type="email"
                               autocomplete="email"
                               placeholder="Seu melhor e-mail"
                               @bind="_email" />
