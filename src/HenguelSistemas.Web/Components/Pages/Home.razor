    <script>
        window.startCountdown = function (endDateIso) {
            const end = new Date(endDateIso).getTime();
            const el = document.getElementById("countdown");

            function tick() {
                const now = new Date().getTime();
                const diff = end - now;

                if (diff <= 0) {
                    el.innerHTML = "⏰ Último dia!";
                    return;
                }

                const d = Math.floor(diff / (1000 * 60 * 60 * 24));
                const h = Math.floor((diff / (1000 * 60 * 60)) % 24);
                const m = Math.floor((diff / (1000 * 60)) % 60);

                el.innerHTML = `⏳ <strong>${d}d ${h}h ${m}m</strong> para acabar`;
            }

            tick();
            setInterval(tick, 60000);
        };

        window.initPhoneScroll = function () {
            const light = document.getElementById('resp-phone-light');
            const dark  = document.getElementById('resp-phone-dark');
            const section = document.getElementById('resp-phones');
            if (!light || !dark || !section) return;

            function onScroll() {
                const rect = section.getBoundingClientRect();
                const windowH = window.innerHeight;

                const progress = Math.max(0, Math.min(1,
                    (windowH - rect.top) / (windowH + rect.height)
                ));

                // Afastamento vertical: light sobe, dark desce
                const spread = progress * 40;

                light.style.transform = `translateX(-58%) rotate(-6deg) translateY(-${spread}px)`;
                dark.style.transform  = `translateX(-38%) rotate(4deg) translateY(${spread}px)`;
            }

            window.addEventListener('scroll', onScroll, { passive: true });
            onScroll();
        };

    </script>

