@code {

    private DateTime _countdownEnd = DateTime.UtcNow.AddDays(7);
    private string _name    = "";
    private string _email   = "";
    private bool   _consent;
    private bool   _loading;
    private bool   _submitted;

    private string _formMessage  = "";
    private string _formMsgClass = "";

    private int _waitlistCount;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _waitlistCount = await WaitlistSvc.GetCountAsync();
        }
        catch
        {
            _waitlistCount = 0;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            await JS.InvokeVoidAsync("startCountdown", _countdownEnd.ToString("O"));
            await JS.InvokeVoidAsync("initPhoneScroll");
            var ip = HttpContextAccessor.HttpContext?.Connection.RemoteIpAddress?.ToString();
            var ua = HttpContextAccessor.HttpContext?.Request.Headers["User-Agent"].ToString();
            await VisitService.TrackAsync("/", ip, ua);
        }
        catch { }
    }

    private bool IsValidEmail(string email) =>
        !string.IsNullOrWhiteSpace(email) &&
        System.Text.RegularExpressions.Regex.IsMatch(
            email,
            @"^[^@\s]+@[^@\s]+\.[^@\s]+$"
        );

    private async Task SubmitWaitlistAsync()
    {
        if (string.IsNullOrWhiteSpace(_name) || !IsValidEmail(_email) || !_consent)
        {
            _formMessage  = "⚠️ Preencha todos os campos corretamente.";
            _formMsgClass = "error";
            return;
        }

        _loading = true;

        bool success;
        string message;
        try
        {
            (success, message) = await WaitlistSvc.RegisterAsync(
                _name.Trim(),
                _email.Trim().ToLower(),
                _consent
            );
        }
        catch
        {
            _formMessage  = "❌ Erro de conexão. Tente novamente.";
            _formMsgClass = "error";
            _loading = false;
            return;
        }

        if (success)
        {
            _formMessage  = "✅ Cadastro realizado! Te avisamos no lançamento 🚀";
            _formMsgClass = "success";
            _submitted    = true;
            _waitlistCount++;
            try { await JS.InvokeVoidAsync("_burst"); } catch { }
        }
        else
        {
            _formMessage  = message;
            _formMsgClass = "error";
        }

        _loading = false;
    }

    private record WaitlistCountResult(int Count);
}
