    <!-- ══════════════════════ FAQ ══════════════════════ -->
    <section id="faq">
        <div class="hw-wrap">
            <span class="section-tag">Dúvidas Frequentes</span>
            <h2 class="section-title" style="margin-bottom:40px;">Perguntas frequentes</h2>

            <div class="faq-list">
                <div class="faq-item">
                    <button class="faq-question"
                            aria-expanded="false"
                            aria-controls="faq-1"
                            onclick="const a=this.nextElementSibling;a.classList.toggle('open');this.setAttribute('aria-expanded',this.getAttribute('aria-expanded')==='true'?'false':'true');">
                        Quanto custa o Henguel Agenda?
                        <span class="faq-arrow">▼</span>
